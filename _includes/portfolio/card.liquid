{% assign item = include.item %}
<article class="portfolio-card portfolio-card--{{ item.portfolio_type }}">
  <a class="portfolio-card-image" href="{{ item.url | relative_url }}">
    <img src="{{ item.image | relative_url }}" alt="{{ item.image_alt }}" loading="lazy">
    <span class="portfolio-card-kind">
      {% if item.portfolio_type == "paper" %}Manuscript{% elsif item.portfolio_type == "note" %}Study notes{% else %}Applied / software{% endif %}
    </span>
  </a>
  <div class="portfolio-card-body">
    <div class="portfolio-card-meta">
      <span class="portfolio-label">{{ item.label }}</span>
      <span>{{ item.status }}</span>
    </div>
    <h3><a href="{{ item.url | relative_url }}">{{ item.card_title | default: item.title }}</a></h3>
    <p>{{ item.summary }}</p>
    {% if item.formula and item.portfolio_type == "note" %}
      <div class="portfolio-formula portfolio-math-display">$$ {{ item.formula }} $$</div>
    {% endif %}
    <div class="portfolio-tags" aria-label="Topics">
      {% for tag in item.tags %}<span>{{ tag }}</span>{% endfor %}
    </div>
  </div>
</article>
