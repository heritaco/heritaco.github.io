<header>
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" aria-label="Primary navigation">
    <div class="container">
      <a class="navbar-brand title font-weight-lighter" href="{{ '/' | relative_url }}">
        <span class="font-weight-bold">Heriberto</span> Espino Montelongo
      </a>
      <button class="navbar-toggler collapsed navbar-toggler-main" type="button" data-nav-toggle="navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>
      <div class="collapse navbar-collapse navbar-collapse-main" id="navbarNav">
        <ul class="navbar-nav navbar-menu-list flex-nowrap">
          {% assign nav_items = "Home|/,Papers|/papers/,Projects|/projects/,Notes|/notes/,Repositories|/repositories/,CV|/cv/,Contact|/#contact" | split: "," %}
          {% for nav_item in nav_items %}
            {% assign parts = nav_item | split: "|" %}
            {% assign nav_title = parts[0] %}
            {% assign nav_url = parts[1] %}
            <li class="nav-item {% if nav_url != '/#contact' and page.url == nav_url %}active{% endif %}">
              <a class="nav-link" href="{{ nav_url | relative_url }}">{{ nav_title }}</a>
            </li>
          {% endfor %}
          {% if site.search_enabled %}
            <li class="nav-item">
              <button id="search-toggle" type="button" title="Search" aria-label="Open search">
                <span class="nav-link"><kbd>Ctrl K</kbd> <i class="fa-solid fa-magnifying-glass"></i></span>
              </button>
            </li>
          {% endif %}
          {% if site.enable_darkmode %}
            <li class="toggle-container">
              <button id="light-toggle" type="button" title="Change theme" aria-label="Change color theme">
                <i class="fa-half-sun-moon" id="light-toggle-system"></i>
                <i class="fa-solid fa-moon" id="light-toggle-dark"></i>
                <i class="fa-solid fa-sun" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <progress id="progress" value="0"><span class="progress-bar"></span></progress>
  {% endif %}
</header>
